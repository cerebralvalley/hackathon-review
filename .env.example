# API keys for hackathon-reviewer
# Copy this file to .env and fill in your keys.

# Required for code review (if using Anthropic provider)
ANTHROPIC_API_KEY=

# Required for video analysis (and optional Gemini code review)
GEMINI_API_KEY=

# Optional: handle age-restricted / sign-in-required YouTube videos.
# Two ways to pass cookies to yt-dlp; pick one.
#
# A) Cookies file (most reliable on macOS — Chrome's v10 cookies are
#    keychain-encrypted and yt-dlp can't read them from a subprocess):
#    Install a browser extension like "Get cookies.txt LOCALLY", export
#    youtube.com cookies to a Netscape-format .txt file, then point at it:
# YTDLP_COOKIES_FILE=/path/to/youtube_cookies.txt
#
# B) Live browser cookies (works on Linux / Windows; Mac Chrome blocked):
#    chrome | firefox | safari | edge | brave | opera | vivaldi | chromium
#    Make sure you're signed into YouTube in that browser.
# YTDLP_COOKIES_FROM_BROWSER=firefox
